{
  "name": "@agent-platform/platform-core",
  "version": "0.1.0",
  "description": "Agent core module - Claude SDK integration with session and streaming support",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "node --test dist/tests/**/*.test.js",
    "clean": "node -e \"const fs=require('node:fs');fs.rmSync('dist',{recursive:true,force:true});fs.rmSync('runtime/tmp',{recursive:true,force:true});\""
  },
  "keywords": [
    "agent-platform",
    "platform-core",
    "agent-core",
    "claude-sdk",
    "streaming"
  ],
  "author": "Agent Platform Team",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.72"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
