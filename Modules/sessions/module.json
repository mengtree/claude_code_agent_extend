{
  "moduleId": "sessions",
  "name": "Sessions Module",
  "version": "0.1.0",
  "description": "会话管理模块 - 提供会话创建、查询、管理和对话功能",
  "kind": "manager",
  "entry": {
    "command": "node",
    "args": ["dist/index.js"]
  },
  "startup": {
    "autoStart": true,
    "daemon": true,
    "restartPolicy": "on-failure"
  },
  "healthCheck": {
    "type": "http",
    "path": "/health",
    "intervalMs": 15000,
    "timeoutMs": 3000,
    "unhealthyThreshold": 3
  },
  "configSchema": {
    "type": "object",
    "properties": {
      "port": {
        "type": "number",
        "description": "HTTP 服务端口",
        "default": 3000
      },
      "host": {
        "type": "string",
        "description": "HTTP 服务监听地址",
        "default": "127.0.0.1"
      },
      "logLevel": {
        "type": "string",
        "enum": ["debug", "info", "warn", "error"],
        "description": "日志级别",
        "default": "info"
      },
      "dataDir": {
        "type": "string",
        "description": "数据目录路径",
        "default": "./runtime/data"
      },
      "sessionTimeoutDays": {
        "type": "number",
        "description": "会话超时天数",
        "default": 30
      },
      "asyncMessage": {
        "type": "object",
        "description": "异步消息配置",
        "properties": {
          "maxConcurrentTasks": {
            "type": "number",
            "description": "最大并发任务数",
            "default": 10
          },
          "taskTimeoutMs": {
            "type": "number",
            "description": "任务超时时间（毫秒）",
            "default": 300000
          },
          "maxRetries": {
            "type": "number",
            "description": "失败重试次数",
            "default": 2
          }
        }
      }
    }
  },
  "capabilities": [
    {
      "action": "create_session",
      "description": "创建新会话",
      "requestSchema": {
        "type": "object",
        "properties": {
          "externalSource": {
            "type": "string",
            "description": "外部系统来源标识"
          },
          "externalConversationId": {
            "type": "string",
            "description": "外部会话 ID"
          }
        }
      },
      "responseSchema": {
        "type": "object",
        "properties": {
          "sessionId": { "type": "string" },
          "claudeSessionId": { "type": "string" },
          "createdAt": { "type": "string" }
        }
      },
      "timeoutMs": 5000,
      "idempotent": false
    },
    {
      "action": "get_session",
      "description": "获取会话信息",
      "requestSchema": {
        "type": "object",
        "properties": {
          "sessionId": {
            "type": "string",
            "description": "会话 ID"
          }
        },
        "required": ["sessionId"]
      },
      "responseSchema": {
        "type": "object",
        "properties": {
          "sessionId": { "type": "string" },
          "claudeSessionId": { "type": "string" },
          "status": { "type": "string" },
          "createdAt": { "type": "string" },
          "lastActiveAt": { "type": "string" },
          "externalMappings": { "type": "array" }
        }
      },
      "timeoutMs": 3000,
      "idempotent": true
    },
    {
      "action": "list_sessions",
      "description": "列出会话",
      "requestSchema": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "number",
            "description": "返回数量限制"
          },
          "status": {
            "type": "string",
            "enum": ["active", "deleted"],
            "description": "会话状态过滤"
          }
        }
      },
      "responseSchema": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "sessionId": { "type": "string" },
            "claudeSessionId": { "type": "string" },
            "status": { "type": "string" },
            "createdAt": { "type": "string" },
            "lastActiveAt": { "type": "string" }
          }
        }
      },
      "timeoutMs": 3000,
      "idempotent": true
    },
    {
      "action": "delete_session",
      "description": "删除会话",
      "requestSchema": {
        "type": "object",
        "properties": {
          "sessionId": {
            "type": "string"
          }
        },
        "required": ["sessionId"]
      },
      "responseSchema": {
        "type": "object",
        "properties": {
          "deleted": { "type": "boolean" },
          "sessionId": { "type": "string" }
        }
      },
      "timeoutMs": 5000,
      "idempotent": true
    },
    {
      "action": "find_by_external",
      "description": "根据外部映射查找会话",
      "requestSchema": {
        "type": "object",
        "properties": {
          "source": { "type": "string" },
          "conversationId": { "type": "string" }
        },
        "required": ["source", "conversationId"]
      },
      "responseSchema": {
        "type": "object",
        "properties": {
          "sessionId": { "type": "string" },
          "claudeSessionId": { "type": "string" },
          "status": { "type": "string" }
        }
      },
      "timeoutMs": 3000,
      "idempotent": true
    },
    {
      "action": "update_session",
      "description": "更新会话信息",
      "requestSchema": {
        "type": "object",
        "properties": {
          "sessionId": { "type": "string" },
          "claudeSessionId": { "type": "string" },
          "status": { "type": "string", "enum": ["active", "deleted"] }
        },
        "required": ["sessionId"]
      },
      "responseSchema": {
        "type": "object",
        "properties": {
          "sessionId": { "type": "string" },
          "claudeSessionId": { "type": "string" },
          "status": { "type": "string" }
        }
      },
      "timeoutMs": 5000,
      "idempotent": false
    },
    {
      "action": "submit_message",
      "description": "提交用户消息进行对话",
      "requestSchema": {
        "type": "object",
        "properties": {
          "sessionId": { "type": "string" },
          "message": { "type": "string" },
          "stream": { "type": "boolean", "default": false }
        },
        "required": ["sessionId", "message"]
      },
      "responseSchema": {
        "type": "object",
        "properties": {
          "response": { "type": "string" },
          "usage": { "type": "object" }
        }
      },
      "timeoutMs": 120000,
      "idempotent": false
    },
    {
      "action": "submit_message_async",
      "description": "异步提交用户消息进行对话，立即返回消息ID，结果通过消息总线推送",
      "requestSchema": {
        "type": "object",
        "properties": {
          "sessionId": { "type": "string" },
          "message": { "type": "string" },
          "callbackTopic": { "type": "string", "description": "结果回调主题" }
        },
        "required": ["sessionId", "message"]
      },
      "responseSchema": {
        "type": "object",
        "properties": {
          "sessionId": { "type": "string" },
          "messageId": { "type": "string" },
          "taskId": { "type": "string" },
          "status": { "type": "string", "enum": ["pending", "processing", "completed", "failed"] }
        }
      },
      "timeoutMs": 5000,
      "idempotent": false
    },
    {
      "action": "async_message_result",
      "description": "异步消息处理结果通知",
      "requestSchema": {
        "type": "object",
        "properties": {
          "sessionId": { "type": "string" },
          "messageId": { "type": "string" },
          "userMessage": { "type": "object" },
          "reply": { "type": "object" },
          "ok": { "type": "boolean" },
          "error": { "type": "string" }
        }
      },
      "responseSchema": {
        "type": "object",
        "properties": {
          "acknowledged": { "type": "boolean" }
        }
      },
      "timeoutMs": 5000,
      "idempotent": true
    }
  ],
  "dataPolicy": {
    "isolated": true,
    "dataDir": "runtime/data",
    "logDir": "runtime/logs",
    "tmpDir": "runtime/tmp"
  },
  "permissions": {
    "workspaceRead": true,
    "workspaceWrite": false,
    "network": true,
    "allowedEndpoints": ["http://127.0.0.1:*", "https://api.anthropic.com:*"]
  },
  "dependencies": {
    "platform-core": ">=0.1.0"
  }
}
